{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "crons": [
    { "path": "/api/v1/jobs/budget-reconciliation", "schedule": "0 9 * * *" },
    { "path": "/api/v1/jobs/scenario-recalc", "schedule": "*/5 * * * *" }
  ]
}
